9. 最终 feasibility 汇总表

SELECT
  '01_aSAH_admissions' AS step,
  COUNT(DISTINCT hadm_id) AS n
FROM `mimic-study-498508.ash_study.asah_cohort`
UNION ALL
SELECT
  '02_aSAH_with_ICU' AS step,
