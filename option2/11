  '03_Hb_available_within_10d' AS step,
  COUNT(DISTINCT hadm_id) AS n
FROM `mimic-study-498508.ash_study.asah_hb_10d`
UNION ALL
SELECT
  '04_Hb_le_10_within_10d' AS step,
  COUNT(DISTINCT hadm_id) AS n
FROM `mimic-study-498508.ash_study.asah_anemia_index`
UNION ALL
SELECT
  '05_RBC_within_24h_after_Hb_le_10' AS step,
