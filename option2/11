下面是方案B完整SQL流程，适合你的项目：

Project ID: mimic-study-498508
Dataset ID: ash_study

核心定义：

aSAH患者
+ 有ICU stay
+ 入院后10天内首次 Hb ≤10 g/dL
= 入组患者

⸻

0. 创建 dataset

CREATE SCHEMA IF NOT EXISTS `mimic-study-498508.ash_study`;

⸻

1. 建立 aSAH 队列

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_cohort` AS
SELECT DISTINCT
    d.subject_id,
    d.hadm_id
FROM `physionet-data.mimiciv_3_1_hosp.diagnoses_icd` d
WHERE
    (d.icd_version = 9 AND d.icd_code = '430')
 OR (d.icd_version = 10 AND STARTS_WITH(d.icd_code, 'I60'));

统计：

SELECT
  COUNT(DISTINCT subject_id) AS patients,
  COUNT(DISTINCT hadm_id) AS admissions
FROM `mimic-study-498508.ash_study.asah_cohort`;

⸻

2. 连接住院信息 + ICU信息

这里保留每次 aSAH 住院的第一次 ICU stay。

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_icu` AS
WITH icu_ranked AS (
  SELECT
      i.subject_id,
      i.hadm_id,
      i.stay_id,
      i.intime,
      i.outtime,
      ROW_NUMBER() OVER (
        PARTITION BY i.subject_id, i.hadm_id
        ORDER BY i.intime
      ) AS rn
  FROM `physionet-data.mimiciv_3_1_icu.icustays` i
)
SELECT
    a.subject_id,
    a.hadm_id,
    icu.stay_id,
    adm.admittime,
    adm.dischtime,
    icu.intime AS icu_intime,
    icu.outtime AS icu_outtime
FROM `mimic-study-498508.ash_study.asah_cohort` a
JOIN `physionet-data.mimiciv_3_1_hosp.admissions` adm
  ON a.hadm_id = adm.hadm_id
JOIN icu_ranked icu
  ON a.hadm_id = icu.hadm_id
WHERE icu.rn = 1;

统计：

SELECT
  COUNT(DISTINCT subject_id) AS patients,
  COUNT(DISTINCT hadm_id) AS admissions,
  COUNT(DISTINCT stay_id) AS icu_stays
FROM `mimic-study-498508.ash_study.asah_icu`;

⸻

3. 提取入院后10天内 Hb

主分析建议用正式 CBC Hb：

Hemoglobin = itemid 51222
CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_hb_10d` AS
SELECT
    a.subject_id,
    a.hadm_id,
    a.stay_id,
    l.charttime,
    l.valuenum AS hemoglobin
FROM `mimic-study-498508.ash_study.asah_icu` a
JOIN `physionet-data.mimiciv_3_1_hosp.labevents` l
  ON a.hadm_id = l.hadm_id
WHERE l.itemid = 51222
  AND l.valuenum IS NOT NULL
  AND l.valuenum BETWEEN 3 AND 25
  AND l.charttime >= a.admittime
  AND l.charttime < DATETIME_ADD(a.admittime, INTERVAL 10 DAY);

统计 Hb 覆盖：

SELECT
  COUNT(*) AS hb_rows,
  COUNT(DISTINCT subject_id) AS patients_with_hb,
  COUNT(DISTINCT hadm_id) AS admissions_with_hb,
  COUNT(DISTINCT stay_id) AS stays_with_hb
FROM `mimic-study-498508.ash_study.asah_hb_10d`;

⸻

4. 定义贫血：首次 Hb ≤10

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_anemia_index` AS
SELECT
    subject_id,
    hadm_id,
    stay_id,
    charttime AS index_time,
    hemoglobin AS index_hb
FROM (
    SELECT
        *,
        ROW_NUMBER() OVER (
          PARTITION BY subject_id, hadm_id
          ORDER BY charttime
        ) AS rn
    FROM `mimic-study-498508.ash_study.asah_hb_10d`
    WHERE hemoglobin <= 10
)
WHERE rn = 1;

统计：

SELECT
  COUNT(DISTINCT subject_id) AS anemia_patients,
  COUNT(DISTINCT hadm_id) AS anemia_admissions,
  COUNT(DISTINCT stay_id) AS anemia_icu_stays
FROM `mimic-study-498508.ash_study.asah_anemia_index`;

⸻

5. 找 RBC 输血 itemid

先运行：

SELECT
  itemid,
  label,
  category,
  unitname
FROM `physionet-data.mimiciv_3_1_icu.d_items`
WHERE LOWER(label) LIKE '%red blood%'
   OR LOWER(label) LIKE '%packed%'
   OR LOWER(label) LIKE '%prbc%'
ORDER BY label;

然后建立 RBC itemid 表：

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.rbc_itemids` AS
SELECT
  itemid,
  label,
  category,
  unitname
FROM `physionet-data.mimiciv_3_1_icu.d_items`
WHERE LOWER(label) LIKE '%red blood%'
   OR LOWER(label) LIKE '%packed%'
   OR LOWER(label) LIKE '%prbc%';

⸻

6. 提取 ICU 内 RBC 输血事件

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_rbc_events` AS
SELECT
    i.subject_id,
    i.hadm_id,
    i.stay_id,
    i.starttime,
    i.endtime,
    i.itemid,
    d.label,
    i.amount,
    i.amountuom
FROM `physionet-data.mimiciv_3_1_icu.inputevents` i
JOIN `mimic-study-498508.ash_study.rbc_itemids` d
  ON i.itemid = d.itemid
JOIN `mimic-study-498508.ash_study.asah_anemia_index` a
  ON i.stay_id = a.stay_id
WHERE i.starttime IS NOT NULL;

⸻

7. 统计 Hb≤10 后是否输注 RBC

24小时内输血

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_treatment_24h` AS
SELECT
    a.subject_id,
    a.hadm_id,
    a.stay_id,
    a.index_time,
    a.index_hb,
    CASE
      WHEN COUNT(r.starttime) > 0 THEN 1
      ELSE 0
    END AS rbc_24h,
    MIN(r.starttime) AS first_rbc_time_24h
FROM `mimic-study-498508.ash_study.asah_anemia_index` a
LEFT JOIN `mimic-study-498508.ash_study.asah_rbc_events` r
  ON a.stay_id = r.stay_id
 AND r.starttime >= a.index_time
 AND r.starttime < DATETIME_ADD(a.index_time, INTERVAL 24 HOUR)
GROUP BY
    a.subject_id,
    a.hadm_id,
    a.stay_id,
    a.index_time,
    a.index_hb;

统计：

SELECT
  COUNT(*) AS anemia_patients,
  SUM(rbc_24h) AS rbc_24h_patients,
  COUNT(*) - SUM(rbc_24h) AS no_rbc_24h_patients,
  ROUND(SUM(rbc_24h) / COUNT(*) * 100, 1) AS rbc_24h_percent
FROM `mimic-study-498508.ash_study.asah_treatment_24h`;

⸻

8. 同时统计 48小时内输血

CREATE OR REPLACE TABLE `mimic-study-498508.ash_study.asah_treatment_48h` AS
SELECT
    a.subject_id,
    a.hadm_id,
    a.stay_id,
    a.index_time,
    a.index_hb,
    CASE
      WHEN COUNT(r.starttime) > 0 THEN 1
      ELSE 0
    END AS rbc_48h,
    MIN(r.starttime) AS first_rbc_time_48h
FROM `mimic-study-498508.ash_study.asah_anemia_index` a
LEFT JOIN `mimic-study-498508.ash_study.asah_rbc_events` r
  ON a.stay_id = r.stay_id
 AND r.starttime >= a.index_time
 AND r.starttime < DATETIME_ADD(a.index_time, INTERVAL 48 HOUR)
GROUP BY
    a.subject_id,
    a.hadm_id,
    a.stay_id,
    a.index_time,
    a.index_hb;

统计：

SELECT
  COUNT(*) AS anemia_patients,
  SUM(rbc_48h) AS rbc_48h_patients,
  COUNT(*) - SUM(rbc_48h) AS no_rbc_48h_patients,
  ROUND(SUM(rbc_48h) / COUNT(*) * 100, 1) AS rbc_48h_percent
FROM `mimic-study-498508.ash_study.asah_treatment_48h`;

